<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<featureModel>
	<properties>
		<graphics key="autolayoutconstraints" value="false"/>
		<graphics key="legendautolayout" value="true"/>
		<graphics key="showconstraints" value="true"/>
		<graphics key="showshortnames" value="false"/>
		<graphics key="layout" value="vertical"/>
		<graphics key="showcollapsedconstraints" value="true"/>
		<graphics key="legendhidden" value="false"/>
		<graphics key="layoutalgorithm" value="4"/>
	</properties>
	<struct>
		<and abstract="true" mandatory="true" name="Data Management System">
			<graphics key="collapsed" value="false"/>

			<!-- ============================================================ -->
			<!-- DATA                                                          -->
			<!-- Respondents (6): M=Bli Marthana, D=Bli Dewa, P=Bli Prabu,   -->
			<!--                  T=Pak Toungi, W=Kak Widya, AM=Kak Amel     -->
			<!-- Mandatory threshold: >= 4 out of 6                           -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data">
				<graphics key="collapsed" value="false"/>

				<!-- Batch 6/6 MAND | Stream 1/6 OPT -->
				<and name="Mobility">
					<feature mandatory="true" name="Batch"/>
					<feature name="Stream"/>
				</and>

				<and abstract="true" mandatory="true" name="Data Structure">
					<!-- Quantitative 6/6 MAND | CSV 5/6 MAND -->
					<and mandatory="true" name="Structured">
						<feature mandatory="true" name="Quantitative Data"/>
						<feature mandatory="true" name="CSV"/>
					</and>
					<!-- JSON 0/6 OPT | XML 0/6 OPT -->
					<and name="Semi Structured">
						<feature name="JSON"/>
						<feature name="XML Format"/>
					</and>
					<!-- Imagery 6/6 MAND | Video 2/6 OPT -->
					<and mandatory="true" name="Unstructured">
						<feature mandatory="true" name="Imagery Data"/>
						<feature name="Video Capture"/>
					</and>
				</and>

				<!-- Fusion 5/6 MAND | Incremental 4/6 MAND | Integration 5/6 MAND -->
				<and mandatory="true" name="Data Aggregation">
					<feature mandatory="true" name="Data Fusion"/>
					<feature mandatory="true" name="Incremental Data Ingestion"/>
					<feature mandatory="true" name="Integration"/>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA ACQUISITION                                              -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Acquisition">
				<graphics key="collapsed" value="false"/>

				<and abstract="true" mandatory="true" name="Sensing And Hardware">

					<!-- Moisture 4/6 MAND | Env 4/6 MAND | pH 3/6 OPT -->
					<!-- Rain 3/6 OPT | Gas 1/6 OPT | Nutrient 1/6 OPT | Thermal 0 OPT | Ultrasonic 0 OPT -->
					<and mandatory="true" name="Ground Sensing IoT Sensor">
						<feature mandatory="true" name="Moisture Sensor"/>
						<feature mandatory="true" name="Environmental Sensor"/>
						<feature name="pH Sensor"/>
						<feature name="Rain Sensor"/>
						<feature name="Gas Sensor"/>
						<feature name="Nutrient Sensor"/>
						<feature name="Thermal Sensor"/>
						<feature name="Ultrasonic Sensor"/>
					</and>

					<!-- Satellite 5/6 MAND | Aerial UAV 4/6 MAND | LiDAR 0 OPT -->
					<and mandatory="true" name="Remote Sensing">
						<feature mandatory="true" name="Satellite"/>
						<feature mandatory="true" name="Aerial UAV"/>
						<feature name="LiDAR"/>
					</and>

					<!-- RGB 6/6 MAND | Multispectral 2/6 OPT | Thermal 1/6 OPT | Hyperspectral 0 OPT -->
					<or mandatory="true" name="Camera">
						<feature mandatory="true" name="RGB Camera"/>
						<feature name="Multispectral Camera"/>
						<feature name="Thermal Camera"/>
						<feature name="Hyperspectral Camera"/>
					</or>

					<!-- GPS 6/6 MAND | GIS 1/6 OPT | GNSS 0 OPT | VRT 0 OPT -->
					<and abstract="true" mandatory="true" name="Spatial Technologies">
						<feature mandatory="true" name="GPS"/>
						<feature name="GIS"/>
						<feature name="GNSS"/>
						<feature name="Variable Rate Technology"/>
					</and>

					<!-- Weather Station 4/6 MAND | PC 3/6 OPT | Microcontroller 2/6 OPT | PCB 1/6 OPT -->
					<feature mandatory="true" name="Weather Station"/>
					<feature name="PC"/>
					<feature name="Microcontroller"/>
					<feature name="PCB"/>
				</and>

				<!-- UAV Drone 4/6 MAND | others < 4 OPT -->
				<and name="Smart Machinery">
					<feature mandatory="true" name="UAV Drone"/>
					<feature name="UGV"/>
					<feature name="Autonomous Tractors"/>
					<feature name="Robotic Harvesters"/>
					<feature name="Agro Bots"/>
					<feature name="Autonomous Vehicles"/>
				</and>

				<!-- WiFi 6/6 MAND | HTTPS 6/6 MAND | Cellular 3/6 OPT | others OPT -->
				<and abstract="true" mandatory="true" name="Data Transfer Communication">
					<and name="Wireless Sensor Network">
						<feature name="ZigBee"/>
						<feature name="LoRaWAN"/>
					</and>
					<feature mandatory="true" name="WiFi"/>
					<feature name="Bluetooth"/>
					<feature name="RFID"/>
					<feature name="NFC"/>
					<feature name="I2C"/>
					<feature name="Cellular"/>
					<feature name="CANBUS"/>
					<feature name="ISOBUS"/>
					<or abstract="true" name="Application Protocols">
						<feature mandatory="true" name="HTTPS"/>
						<feature name="MQTT"/>
						<feature name="CoAP"/>
						<feature name="AMQP"/>
					</or>
					<feature name="IoT Brokers"/>
				</and>

				<!-- Manual Entry 6/6 MAND | Batch Upload 5/6 MAND | Cloud Upload 6/6 MAND -->
				<!-- Tamper Proof 4/6 MAND | Timestamp 6/6 MAND | GPS Coordinates 5/6 MAND -->
				<!-- Stream Upload 1/6 OPT | Local DB 0 OPT | Auto Logs 1/6 OPT | others OPT -->
				<and abstract="true" mandatory="true" name="Data Loading And Logging">
					<feature mandatory="true" name="Data Ingestion Manual Entry"/>
					<and mandatory="true" name="Uploading Mechanism">
						<feature mandatory="true" name="Batch Uploading"/>
						<feature name="Stream Uploading"/>
					</and>
					<and mandatory="true" name="Target Storage">
						<feature mandatory="true" name="Cloud Database Uploading"/>
						<feature name="Local Database Uploading"/>
					</and>
					<and mandatory="true" name="Log Types">
						<feature mandatory="true" name="Tamper Proof Logs"/>
						<feature name="Automated Field Operation Logs"/>
						<feature name="System Event Logs"/>
					</and>
					<feature name="Terminal Logging"/>
					<and mandatory="true" name="Logged Parameters">
						<feature mandatory="true" name="Timestamp"/>
						<feature mandatory="true" name="GPS Coordinates"/>
					</and>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA STORAGE                                                  -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Storage">
				<graphics key="collapsed" value="false"/>

				<!-- Cloud 6/6 MAND | others OPT -->
				<or abstract="true" mandatory="true" name="Computing Infrastructure">
					<feature mandatory="true" name="Cloud Computing"/>
					<feature name="Edge Computing"/>
					<feature name="LocalHost"/>
					<feature name="StandAlone"/>
					<feature name="MicroSD"/>
				</or>

				<!-- SQL 5/6 MAND | others OPT -->
				<and abstract="true" mandatory="true" name="Database Systems">
					<feature mandatory="true" name="SQL Relational Database"/>
					<feature name="NoSQL Distributed DB"/>
					<feature name="Data Warehouse"/>
					<feature name="Metadata Management"/>
					<feature name="Data Lake"/>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA PROCESSING                                               -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Processing">
				<graphics key="collapsed" value="false"/>

				<and abstract="true" mandatory="true" name="Data Preprocessing And Preparation">
					<!-- Normalization 6/6 MAND | Imputation 5/6 MAND | others OPT -->
					<and mandatory="true" name="Data Cleansing">
						<feature mandatory="true" name="Normalization"/>
						<feature mandatory="true" name="Imputation"/>
						<feature name="Numeric Transformation"/>
						<feature name="Feature Engineering"/>
						<feature name="Data Augmentation"/>
						<feature name="Image Resizing"/>
						<feature name="Color Normalization"/>
						<feature name="Brightness Adjustment"/>
						<feature name="Noise Injection"/>
						<feature name="Encoding"/>
					</and>
					<!-- all < 4 OPT -->
					<and name="Data Splitting">
						<feature name="Training"/>
						<feature name="Testing"/>
					</and>
					<feature name="Feature Extraction"/>
					<and name="Data Pipeline Tools">
						<feature name="Pandas"/>
						<feature name="Dask"/>
						<feature name="Generators"/>
					</and>
				</and>

				<!-- all < 4 OPT -->
				<and abstract="true" name="Image Processing">
					<and name="Photogrammetry">
						<feature name="Orthophoto"/>
						<feature name="P3D DEMs"/>
					</and>
					<and name="Image Annotation">
						<feature name="CVAT"/>
						<feature name="Labeling Manual"/>
					</and>
					<and name="Image Analysis">
						<feature name="Object Based"/>
						<feature name="Pixel Based"/>
					</and>
				</and>

				<and abstract="true" mandatory="true" name="Data Analytics Method">
					<!-- No specific algorithm >= 4; OR group kept mandatory from DMS architecture -->
					<or abstract="true" mandatory="true" name="Machine Learning">
						<feature name="Random Forest"/>
						<feature name="SVM"/>
						<feature name="kNN"/>
						<feature name="Decision Tree"/>
						<feature name="Naive Bayes"/>
						<feature name="XGBoost"/>
						<feature name="Gradient Boosting"/>
					</or>
					<!-- all DL < 4 OPT -->
					<and abstract="true" name="Deep Learning">
						<feature name="CNN"/>
						<feature name="RNN"/>
						<feature name="LSTM"/>
						<feature name="BiLSTM"/>
						<feature name="MLP"/>
						<feature name="Mango YOLO"/>
						<feature name="Agro Deep Learning"/>
					</and>
					<!-- all < 4 OPT -->
					<and abstract="true" name="Regression And Classification">
						<feature name="Linear Regression"/>
						<feature name="Polynomial Regression"/>
						<feature name="Multiple Linear Regression"/>
					</and>
					<!-- all 0/6 OPT -->
					<and name="Big Data Analytics And Clustering">
						<feature name="Map Reduce And Spark"/>
						<feature name="Data Mining"/>
					</and>
					<!-- Spatial 2/6 OPT | Geospatial 2/6 OPT -->
					<and name="Statistical And Math Model">
						<feature name="Spatial Analysis"/>
						<feature name="Geospatial Analysis"/>
						<feature name="Invasive Weed Optimization"/>
					</and>
					<!-- Fuzzy 2/6 OPT | others 0 OPT -->
					<and name="Expert System">
						<feature name="Fuzzy Logic"/>
						<feature name="OFIS"/>
						<feature name="Forward Chaining"/>
					</and>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA VISUALIZATION                                            -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Visualization">
				<graphics key="collapsed" value="false"/>

				<!-- Temporal Trend Graph 3/6 OPT | Line 3/6 OPT | others OPT -->
				<and name="Temporal Visualization">
					<feature name="Temporal Trend Graph"/>
					<feature name="Line Graph"/>
					<feature name="Timelines"/>
					<feature name="Scatter Plot"/>
				</and>

				<!-- Comparison Chart 5/6 MAND | Bar 2/6 OPT | others OPT -->
				<and mandatory="true" name="Multidimensional Visualization">
					<feature mandatory="true" name="Comparison Chart"/>
					<feature name="Bar Graph"/>
					<feature name="Histogram"/>
					<feature name="Box Plot"/>
					<feature name="Pie Chart"/>
				</and>

				<!-- Yield Maps 3/6 OPT | Seasonal 4/6 MAND | NDVI 2/6 OPT | others OPT -->
				<and mandatory="true" name="Geospatial Visualization">
					<feature mandatory="true" name="Seasonal Comparison Historical Timeline"/>
					<feature name="Yield Maps"/>
					<feature name="NDVI Map"/>
					<feature name="Soil Maps"/>
					<feature name="Heat Maps Flow Maps"/>
					<feature name="Vegetation Indices Maps"/>
					<feature name="Flow Maps"/>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA MONITORING AND REPORTING                                 -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Monitoring And Reporting">
				<graphics key="collapsed" value="false"/>

				<!-- Mobile 3/6 OPT | Web 3/6 OPT | Windows 0 OPT -->
				<and abstract="true" mandatory="true" name="User Interface">
					<feature name="Mobile Application"/>
					<feature name="Web Application"/>
					<feature name="Windows"/>
				</and>

				<!-- Dashboard 6/6 MAND | Real-Time 4/6 MAND | DSS 6/6 MAND | Alerts 6/6 MAND -->
				<feature mandatory="true" name="Dashboard"/>

				<and mandatory="true" name="Real Time Monitoring">
					<feature name="SCADA"/>
				</and>

				<feature mandatory="true" name="Decision Support System DSS"/>

				<and mandatory="true" name="Alert System">
					<feature mandatory="true" name="Automated Alerts"/>
				</and>

				<and name="Information Management And Reporting">
					<and name="FMIS Tools">
						<feature name="Akkerweb"/>
						<feature name="Agrivi Field View"/>
					</and>
				</and>
			</and>

			<!-- ============================================================ -->
			<!-- DATA SECURITY                                                 -->
			<!-- ============================================================ -->
			<and abstract="true" mandatory="true" name="Data Security">
				<graphics key="collapsed" value="false"/>

				<!-- both 0/6 OPT -->
				<and abstract="true" name="Confidentiality And Privacy">
					<feature name="Federated Learning"/>
					<feature name="Differential Privacy Techniques"/>
				</and>

				<!-- Cryptography 5/6 MAND | others OPT -->
				<and abstract="true" mandatory="true" name="Encryption Security Mechanisms">
					<feature mandatory="true" name="Cryptography Encryption"/>
					<feature name="Homomorphic Encryption"/>
					<feature name="Lightweight Cryptography"/>
				</and>

				<!-- Digital Signature 5/6 MAND -->
				<and abstract="true" mandatory="true" name="Authorization And Authentication">
					<feature mandatory="true" name="Digital Signature"/>
				</and>

				<feature name="Interoperability And Context Management"/>
			</and>

		</and>
	</struct>
</featureModel>